# LLM — choose one provider
LLM_PROVIDER=groq          # "groq" or "gemini"
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Yahoo Mail IMAP
YAHOO_EMAIL=your_yahoo_email@yahoo.com
YAHOO_APP_PASSWORD=your_yahoo_app_password

# Whitelisted sender domains (comma-separated, no spaces)
WHITELISTED_DOMAINS=hdfcbank.com,icicibank.com,axisbank.com,sbicard.com,kotakbank.com,yesbank.in

# Agent thresholds (optional — defaults shown)
OVERSPEND_THRESHOLD=0.25
ANOMALY_MULTIPLIER=2.0
ANOMALY_UNKNOWN_MIN=2000
DUPLICATE_WINDOW_DAYS=7
BUDGET_OVERSHOOT_THRESHOLD=0.20
AGENT_MIN_MONTHS=2

# REA Communication Agent webhook (for WhatsApp alert push)
# Set to your REA server's incoming webhook URL
REA_WEBHOOK_URL=http://localhost:3001/rea/incoming

# API server
API_HOST=0.0.0.0
API_PORT=8000
